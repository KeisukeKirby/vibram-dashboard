generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id                String   @id @default(cuid())
  baseProductName   String   @unique
  brand             String?
  category          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  variants          ProductVariant[]
}

model ProductVariant {
  id                String   @id @default(cuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  skuCode           String?
  barcode           String?
  color             String?
  size              String?
  retailPrice       Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  salesTransactions SalesTransaction[]
  inventorySnapshots InventorySnapshot[]

  // Sometimes SKU or barcode might be unique, but across systems they might differ. 
  // We'll primarily match by (productId, color, size) or SKU.
}

model SalesTransaction {
  id                String   @id @default(cuid())
  sourceType        String   // 'pos_monthly', 'ec_order', 'manual_sheet'
  sourceFileName    String?
  importedAt        DateTime @default(now())
  storeName         String?
  salesChannel      String?
  date              DateTime
  granularity       String   // 'monthly', 'daily'
  variantId         String?
  variant           ProductVariant? @relation(fields: [variantId], references: [id])
  rawProductText    String?  // Keep raw text if matching fails
  quantity          Int
  grossSales        Float?
  discountAmount    Float?
  netSales          Float?
}

model InventorySnapshot {
  id                String   @id @default(cuid())
  variantId         String?
  variant           ProductVariant? @relation(fields: [variantId], references: [id])
  storeName         String?
  snapshotDate      DateTime
  stockQuantity     Int
  importedAt        DateTime @default(now())
}

model ImportLog {
  id                String   @id @default(cuid())
  fileName          String
  sourceType        String
  importedAt        DateTime @default(now())
  status            String   // 'SUCCESS', 'FAILED', 'PARTIAL'
  totalRows         Int
  failedRows        Int
  errorMessage      String?
}
