generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NormalizedSale {
  id           String   @id @default(cuid())
  date         DateTime
  store        String
  channel      String?
  product_name String
  size         String?
  color        String?
  quantity     Int
  amount       Float
  source_file  String
  source_type  String
  importedAt   DateTime @default(now())
}

model InventorySnapshot {
  id                String   @id @default(cuid())
  product_name      String
  size              String?
  color             String?
  storeName         String?
  snapshotDate      DateTime
  stockQuantity     Int
  importedAt        DateTime @default(now())
}

model ImportLog {
  id                String   @id @default(cuid())
  fileName          String
  sourceType        String
  importedAt        DateTime @default(now())
  status            String   // 'SUCCESS', 'FAILED', 'PARTIAL'
  totalRows         Int
  failedRows        Int
  errorMessage      String?
}
